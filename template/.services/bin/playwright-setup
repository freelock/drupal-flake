#!/usr/bin/env bash
# playwright-setup - Configure Playwright for Drupal browser testing
# Usage: playwright-setup [-f]
#   -f: Force overwrite of existing playwright.config.cjs

set -euo pipefail

FORCE=false

while [[ $# -gt 0 ]]; do
  case $1 in
    -f|--force)
      FORCE=true
      shift
      ;;
    -h|--help)
      echo "playwright-setup - Configure Playwright for Drupal browser testing"
      echo "Usage: playwright-setup [-f]"
      echo "  -f, --force  Overwrite existing playwright.config.cjs"
      echo "  -h, --help   Show this help message"
      exit 0
      ;;
    *)
      echo "Unknown parameter: $1"
      echo "Use -h or --help for usage information"
      exit 1
      ;;
  esac
done

PROJECT_ROOT="$PWD"
DOCROOT="${DOCROOT:-web}"
PROJECT_NAME="${PROJECT_NAME:-drupal-demo}"
DOMAIN="${DOMAIN:-$PROJECT_NAME.ddev.site}"
PORT="${PORT:-8088}"
BASE_URL="${SIMPLETEST_BASE_URL:-http://$DOMAIN:$PORT}"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

print_info() { echo -e "${BLUE}ℹ️  $1${NC}"; }
print_success() { echo -e "${GREEN}✅ $1${NC}"; }
print_warning() { echo -e "${YELLOW}⚠️  $1${NC}"; }
print_error() { echo -e "${RED}❌ $1${NC}"; }

print_info "Setting up Playwright for Drupal testing..."
print_info "Using environment:"
print_info "  Base URL: $BASE_URL"
print_info "  Project: $PROJECT_NAME"
print_info "  Docroot: $DOCROOT"

# Check if @playwright/test is available
if [[ ! -f "$PROJECT_ROOT/node_modules/.bin/playwright" ]]; then
  print_warning "@playwright/test is not installed yet."
  print_info "  Run after setup: npm install --save-dev @playwright/test"
fi

# Create playwright.config.cjs (CommonJS avoids ESM/package.json type issues)
CONFIG_FILE="$PROJECT_ROOT/playwright.config.cjs"
if [[ -f "$CONFIG_FILE" ]] && [[ "$FORCE" == "false" ]]; then
  print_warning "playwright.config.cjs already exists. Use -f to overwrite."
else
  cat > "$CONFIG_FILE" << EOF
// @ts-check
// Playwright configuration for Drupal testing
// Generated by drupal-flake playwright-setup
// Run tests with: npx playwright test
// View report with: npx playwright show-report data/playwright-report

const { defineConfig, devices } = require('@playwright/test');

module.exports = defineConfig({
  testDir: './tests/playwright',

  // Per-test timeout (ms)
  timeout: 30000,

  // Global timeout for the whole test run
  globalTimeout: 10 * 60 * 1000,

  // Run tests sequentially - Drupal tests need state isolation
  fullyParallel: false,
  workers: 1,

  // Fail the build on CI if .only is left in test files
  forbidOnly: !!process.env.CI,

  // Retry failed tests once on CI
  retries: process.env.CI ? 1 : 0,

  reporter: [
    ['html', { outputFolder: 'data/playwright-report', open: 'never' }],
    ['list'],
  ],

  use: {
    // Use SIMPLETEST_BASE_URL if set (matches PHPUnit config), else fall back to env or default
    baseURL: process.env.SIMPLETEST_BASE_URL || process.env.PLAYWRIGHT_BASE_URL || '$BASE_URL',

    // Collect traces and screenshots on failure
    trace: 'on-first-retry',
    screenshot: 'only-on-failure',
    video: 'retain-on-failure',

    // Run headless in CI, headed locally (override with PLAYWRIGHT_HEADLESS=true)
    headless: process.env.CI ? true : (process.env.PLAYWRIGHT_HEADLESS === 'true'),
  },

  projects: [
    {
      name: 'chromium',
      use: {
        ...devices['Desktop Chrome'],
        // Use system Chrome when in Nix test shell (PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH)
        // Falls back to Playwright-managed browsers if env var is not set
        launchOptions: process.env.PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH ? {
          executablePath: process.env.PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH,
        } : {},
      },
    },
  ],

  // Output directory for test artifacts
  outputDir: 'data/playwright-results',
});
EOF
  print_success "Created playwright.config.cjs"
fi

# Create test directory structure
mkdir -p "$PROJECT_ROOT/tests/playwright"

# Create example test if none exists
EXAMPLE_TEST="$PROJECT_ROOT/tests/playwright/example.spec.js"
if [[ ! -f "$EXAMPLE_TEST" ]]; then
  cat > "$EXAMPLE_TEST" << 'EOF'
// @ts-check
const { test, expect } = require('@playwright/test');

test.describe('Drupal site', () => {
  test('front page loads', async ({ page }) => {
    await page.goto('/');
    // Verify the page has a title
    await expect(page).toHaveTitle(/.+/);
  });

  test('user login page exists', async ({ page }) => {
    await page.goto('/user/login');
    await expect(page.locator('#edit-name')).toBeVisible();
    await expect(page.locator('#edit-pass')).toBeVisible();
    await expect(page.locator('#edit-submit')).toBeVisible();
  });

  test('admin login', async ({ page }) => {
    // Replace with actual admin credentials for your site
    const adminUser = process.env.DRUPAL_ADMIN_USER || 'admin';
    const adminPass = process.env.DRUPAL_ADMIN_PASS || 'admin';

    await page.goto('/user/login');
    await page.fill('#edit-name', adminUser);
    await page.fill('#edit-pass', adminPass);
    await page.click('#edit-submit');

    // After login, should be on the user profile page
    await expect(page).toHaveURL(/\/user\/\d+/);
  });
});
EOF
  print_success "Created tests/playwright/example.spec.js"
fi

# Create output directories
mkdir -p "$PROJECT_ROOT/data/playwright-report"
mkdir -p "$PROJECT_ROOT/data/playwright-results"

print_success "Playwright setup complete!"
print_info ""
print_info "Next steps:"
print_info "  1. Install @playwright/test (in the test shell):"
print_info "     nix develop .#test"
print_info "     npm install --save-dev @playwright/test"
print_info ""
print_info "  2. Make sure the dev server is running:"
print_info "     start-detached"
print_info ""
print_info "  3. Run tests (from the test shell):"
print_info "     npx playwright test"
print_info ""
print_info "  4. View HTML report:"
print_info "     npx playwright show-report data/playwright-report"
print_info ""
print_info "Browser configuration (set automatically in 'nix develop .#test'):"
if [[ -n "${PLAYWRIGHT_BROWSERS_PATH:-}" ]]; then
  print_success "  PLAYWRIGHT_BROWSERS_PATH=$PLAYWRIGHT_BROWSERS_PATH"
elif [[ -n "${PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH:-}" ]]; then
  print_success "  PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=$PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH"
else
  print_warning "  No browser configured. Enter 'nix develop .#test' for auto-detection."
  print_info "  Or set manually: export PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/path/to/chrome"
fi
print_info ""
print_info "NixOS note: The test shell uses pkgs.playwright-driver.browsers from nixpkgs."
print_info "  For exact Playwright version pinning, see:"
print_info "  https://github.com/halfwhey/nix-playwright-nightly (Linux + macOS)"
print_info "  https://github.com/pietdevries94/playwright-web-flake (Linux)"
